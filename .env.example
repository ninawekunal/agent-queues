HOST=0.0.0.0
PORT=3000

# Upstash Redis (required for /api/upstash/redis-ping)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash QStash (required for /api/upstash/qstash-publish)
QSTASH_TOKEN=

# Where QStash should deliver message bodies.
# If you want to test against this app, point to:
# https://<your-public-host>/api/upstash/qstash-receiver
QSTASH_DESTINATION_URL=
